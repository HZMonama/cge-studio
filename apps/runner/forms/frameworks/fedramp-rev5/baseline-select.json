      "defaultValue": "",
      "options": [
        { "label": "Select system type", "value": "" },
        { "label": "SaaS", "value": "saas" },
        { "label": "PaaS", "value": "paas" },
        { "label": "IaaS", "value": "iaas" }
      ]
    }
  ],
  "overrides": {},
  "remove": [],
  "order": [
    "impactLevel",
    "systemType"
  ],
  "submitLabel": "Select FedRAMP Baseline"
