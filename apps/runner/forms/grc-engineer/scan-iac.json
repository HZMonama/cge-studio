{
  "mode": "inline",
  "minimumConfiguration": [
    "directory",
    "frameworks"
  ],
  "fields": [
    {
      "name": "directory",
      "label": "Directory",
      "type": "path",
      "required": true,
      "position": "argument",
      "description": "IaC directory to scan.",
      "placeholder": "./terraform"
    },
    {
      "name": "frameworks",
      "label": "Frameworks",
      "type": "multiselect",
      "required": true,
      "position": "argument",
      "description": "Frameworks to scan against.",
      "options": [
        { "label": "SOC 2", "value": "SOC2" },
        { "label": "PCI DSS", "value": "PCI-DSS" },
        { "label": "NIST", "value": "NIST" },
        { "label": "ISO", "value": "ISO" },
        { "label": "GDPR", "value": "GDPR" }
      ]
    },
    {
      "name": "outputFormat",
      "label": "Output Format",
      "type": "select",
      "required": false,
      "position": "argument",
      "description": "Scan output format.",
      "defaultValue": "detailed",
      "options": [
        { "label": "Detailed", "value": "detailed" },
        { "label": "Summary", "value": "summary" },
        { "label": "JSON", "value": "json" },
        { "label": "SARIF", "value": "sarif" }
      ]
    },
    {
      "name": "option",
      "label": "Option",
      "type": "text",
      "required": false,
      "position": "argument",
      "description": "Optional raw option such as --fix, --severity=high, or --exclude=test/."
    }
  ],
  "remove": [
    "directoryToScanEGTerraformK8s)",
    "commaSeparatedFrameworksEGSOC2PCIDSSNIST)",
    "outputFormatOptionalDetailedSummaryJsonSarifDefaultDetailed)",
    "optionsOptionalFixSeverityHighExcludeTest`"
  ],
  "submitLabel": "Run Scan IaC"
}
