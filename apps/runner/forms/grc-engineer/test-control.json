{
  "mode": "inline",
  "minimumConfiguration": [
    "controlId"
  ],
  "fields": [
    {
      "name": "controlId",
      "label": "Control ID Or Name",
      "type": "text",
      "required": true,
      "position": "argument",
      "description": "Control ID or control name to test."
    },
    {
      "name": "cloudProvider",
      "label": "Cloud Provider",
      "type": "select",
      "required": false,
      "position": "argument",
      "description": "Optional cloud provider override. Omit to use the current CLI default.",
      "options": [
        { "label": "AWS", "value": "aws" },
        { "label": "Azure", "value": "azure" },
        { "label": "GCP", "value": "gcp" },
        { "label": "Kubernetes", "value": "kubernetes" }
      ]
    },
    {
      "name": "output",
      "label": "Output Format",
      "type": "select",
      "required": false,
      "flag": "--output",
      "description": "Optional output format override.",
      "options": [
        { "label": "Text", "value": "text" },
        { "label": "JSON", "value": "json" }
      ]
    },
    {
      "name": "verbose",
      "label": "Verbose Output",
      "type": "boolean",
      "required": false,
      "flag": "--verbose",
      "description": "Enable verbose output.",
      "defaultValue": false
    },
    {
      "name": "fixFailures",
      "label": "Fix Failures",
      "type": "boolean",
      "required": false,
      "flag": "--fix-failures",
      "description": "Attempt to fix failures automatically.",
      "defaultValue": false
    }
  ],
  "remove": [
    "controlIDOrNameEGAccessControlAccountManagementAC2EncryptionAtRest)",
    "cloudProviderOptionalAwsAzureGcpKubernetesDefaultAutoDetect)",
    "optionsOptionalVerboseFixFailuresOutputJson`"
  ],
  "order": [
    "controlId",
    "cloudProvider",
    "output",
    "verbose",
    "fixFailures"
  ],
  "submitLabel": "Run Test Control"
}
