{
  "mode": "inline",
  "minimumConfiguration": [
    "frameworks"
  ],
  "fields": [
    {
      "name": "frameworks",
      "label": "Frameworks",
      "type": "multiselect",
      "required": true,
      "position": "argument",
      "description": "Select the frameworks to monitor continuously.",
      "options": [
        { "label": "SOC 2", "value": "SOC2" },
        { "label": "PCI DSS", "value": "PCI-DSS" },
        { "label": "NIST 800-53", "value": "NIST" },
        { "label": "ISO 27001", "value": "ISO" },
        { "label": "All", "value": "ALL" }
      ]
    },
    {
      "name": "schedule",
      "label": "Schedule",
      "type": "select",
      "required": false,
      "position": "argument",
      "description": "Monitoring cadence.",
      "defaultValue": "daily",
      "options": [
        { "label": "Hourly", "value": "hourly" },
        { "label": "Daily", "value": "daily" },
        { "label": "Weekly", "value": "weekly" }
      ]
    },
    {
      "name": "option",
      "label": "Option",
      "type": "text",
      "required": false,
      "position": "argument",
      "description": "Optional alerting or dashboard flag such as --dashboard, --email=security@example.com, or --slack-webhook=URL.",
      "placeholder": "--dashboard"
    }
  ],
  "remove": [
    "commaSeparatedFrameworksEGSOC2PCIDSSNIST)",
    "scheduleOptionalDailyWeeklyHourlyDefaultDaily)",
    "optionsOptionalSlackWebhookURLEmailAddressDashboard`"
  ],
  "submitLabel": "Run Monitor Continuous"
}
