{
  "mode": "inline",
  "minimumConfiguration": [
    "frameworks"
  ],
  "fields": [
    {
      "name": "frameworks",
      "label": "Frameworks",
      "type": "text",
      "required": true,
      "position": "argument",
      "description": "Comma-separated framework codes to optimize together.",
      "placeholder": "SOC2,PCI-DSS,NIST,ISO"
    },
    {
      "name": "outputFormat",
      "label": "Output Format",
      "type": "select",
      "required": false,
      "position": "argument",
      "description": "Optimization report shape. Omit to use the CLI default.",
      "options": [
        { "label": "Roadmap", "value": "roadmap" },
        { "label": "Matrix", "value": "matrix" },
        { "label": "Summary", "value": "summary" }
      ]
    }
  ],
  "remove": [
    "commaSeparatedListOfFrameworksEGSOC2PCIDSSNISTISO)",
    "outputFormatOptionalRoadmapMatrixSummaryDefaultRoadmap)"
  ],
  "order": [
    "frameworks",
    "outputFormat"
  ],
  "submitLabel": "Run Optimize Multi-Framework"
}
