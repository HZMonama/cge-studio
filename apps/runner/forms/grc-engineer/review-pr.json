{
  "mode": "inline",
  "minimumConfiguration": [
    "repository",
    "prNumber"
  ],
  "fields": [
    {
      "name": "repository",
      "label": "Repository",
      "type": "text",
      "required": true,
      "position": "argument",
      "description": "Repository in owner/repo format.",
      "placeholder": "myorg/infrastructure"
    },
    {
      "name": "prNumber",
      "label": "PR Number",
      "type": "number",
      "required": true,
      "position": "argument",
      "description": "Pull request number."
    },
    {
      "name": "framework",
      "label": "Framework",
      "type": "select",
      "required": false,
      "position": "argument",
      "description": "Framework context for the review.",
      "defaultValue": "SOC2",
      "options": [
        { "label": "SOC 2", "value": "SOC2" },
        { "label": "PCI DSS", "value": "PCIDSS" },
        { "label": "ISO 27001", "value": "ISO27001" },
        { "label": "NIST 800-53", "value": "NIST80053" }
      ]
    }
  ],
  "remove": [
    "repositoryRequiredFormatOwnerRepo)",
    "pRNumber",
    "frameworkOptionalDefaultsToSOC2)"
  ],
  "submitLabel": "Run Review PR"
}
