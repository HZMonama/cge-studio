{
  "mode": "inline",
  "minimumConfiguration": [
    "directory",
    "frameworks"
  ],
  "fields": [
    {
      "name": "directory",
      "label": "Directory",
      "type": "path",
      "required": true,
      "position": "argument",
      "description": "IaC directory to scan.",
      "placeholder": "./terraform"
    },
    {
      "name": "frameworks",
      "label": "Frameworks",
      "type": "text",
      "required": true,
      "position": "argument",
      "description": "Comma-separated framework codes to scan against.",
      "placeholder": "SOC2,PCI-DSS,NIST"
    },
    {
      "name": "outputFormat",
      "label": "Output Format",
      "type": "select",
      "required": false,
      "position": "argument",
      "description": "Scan output format. Omit to use the CLI default.",
      "options": [
        { "label": "Detailed", "value": "detailed" },
        { "label": "Summary", "value": "summary" },
        { "label": "JSON", "value": "json" },
        { "label": "SARIF", "value": "sarif" }
      ]
    },
    {
      "name": "fix",
      "label": "Auto-fix",
      "type": "boolean",
      "required": false,
      "flag": "--fix",
      "description": "Apply the script's `--fix` option when available.",
      "defaultValue": false
    },
    {
      "name": "severity",
      "label": "Severity Filter",
      "type": "text",
      "required": false,
      "flag": "--severity",
      "description": "Optional severity filter, for example `high`.",
      "placeholder": "high"
    }
  ],
  "remove": [
    "directoryToScanEGTerraformK8s)",
    "commaSeparatedFrameworksEGSOC2PCIDSSNIST)",
    "outputFormatOptionalDetailedSummaryJsonSarifDefaultDetailed)",
    "optionsOptionalFixSeverityHighExcludeTest`"
  ],
  "order": [
    "directory",
    "frameworks",
    "outputFormat",
    "fix",
    "severity"
  ],
  "submitLabel": "Run Scan IaC"
}
