{
  "mode": "inline",
  "extends": null,
  "minimumConfiguration": [
    "frameworks"
  ],
  "compose": [
    "framework-selection",
    "connector-selection",
    "output-format",
    "report-dir",
    "refresh-flag",
    "offline-flag",
    "quiet-flag"
  ],
  "fields": [
    {
      "name": "cacheDir",
      "label": "Cache Directory",
      "type": "path",
      "required": false,
      "flag": "--cache-dir",
      "description": "Optional findings cache directory override.",
      "placeholder": "~/.cache/claude-grc/findings"
    }
  ],
  "overrides": {
    "frameworks": {
      "label": "Frameworks",
      "required": true,
      "position": "argument",
      "description": "Comma-separated framework aliases or SCF framework IDs to assess."
    },
    "sources": {
      "label": "Sources",
      "flag": "--sources",
      "description": "Comma-separated connector IDs to include in the assessment."
    },
    "output": {
      "label": "Output Format",
      "flag": "--output",
      "description": "Choose the report format to generate when you want to override the CLI default.",
      "options": [
        { "label": "Markdown", "value": "markdown" },
        { "label": "JSON", "value": "json" },
        { "label": "SARIF", "value": "sarif" },
        { "label": "OSCAL Assessment Results", "value": "oscal-ar" }
      ]
    },
    "reportDir": {
      "label": "Report Directory",
      "flag": "--report-dir",
      "description": "Optional output directory for the generated report bundle.",
      "placeholder": "./gap-assessment-run"
    },
    "refresh": {
      "label": "Refresh source findings",
      "flag": "--refresh",
      "description": "Force fresh collection from each selected source before assessment.",
      "defaultValue": false
    },
    "offline": {
      "label": "Offline mode",
      "flag": "--offline",
      "description": "Use cached SCF data only and skip network access.",
      "defaultValue": false
    },
    "quiet": {
      "label": "Quiet output",
      "flag": "--quiet",
      "description": "Suppress progress output to stderr.",
      "defaultValue": false
    }
  },
  "remove": [
    "csv",
    "fmt",
    "path"
  ],
  "order": [
    "frameworks",
    "sources",
    "output",
    "cacheDir",
    "reportDir",
    "refresh",
    "offline",
    "quiet"
  ],
  "submitLabel": "Run Gap Assessment"
}
