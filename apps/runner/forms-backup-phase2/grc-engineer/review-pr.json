{
  "mode": "inline",
  "minimumConfiguration": [
    "repository",
    "prNumber"
  ],
  "fields": [
    {
      "name": "repository",
      "label": "Repository",
      "type": "text",
      "required": true,
      "position": "argument",
      "description": "Repository in owner/repo format.",
      "placeholder": "myorg/infrastructure"
    },
    {
      "name": "prNumber",
      "label": "PR Number",
      "type": "number",
      "required": true,
      "position": "argument",
      "description": "Pull request number."
    },
    {
      "name": "framework",
      "label": "Framework",
      "type": "text",
      "required": false,
      "position": "argument",
      "description": "Optional framework context for the review. Omit to use the CLI default.",
      "placeholder": "SOC2"
    }
  ],
  "remove": [
    "repositoryRequiredFormatOwnerRepo)",
    "pRNumber",
    "frameworkOptionalDefaultsToSOC2)"
  ],
  "submitLabel": "Run Review PR"
}
