{
  "mode": "inline",
  "minimumConfiguration": [
    "frameworks"
  ],
  "fields": [
    {
      "name": "frameworks",
      "label": "Frameworks",
      "type": "text",
      "required": true,
      "position": "argument",
      "description": "Comma-separated framework codes to monitor, or ALL.",
      "placeholder": "SOC2,PCI-DSS,NIST"
    },
    {
      "name": "schedule",
      "label": "Schedule",
      "type": "select",
      "required": false,
      "position": "argument",
      "description": "Monitoring cadence. Omit to use the CLI default.",
      "options": [
        { "label": "Hourly", "value": "hourly" },
        { "label": "Daily", "value": "daily" },
        { "label": "Weekly", "value": "weekly" }
      ]
    },
    {
      "name": "slackWebhook",
      "label": "Slack Webhook",
      "type": "text",
      "required": false,
      "flag": "--slack-webhook",
      "description": "Slack webhook URL for alerts."
    },
    {
      "name": "email",
      "label": "Email",
      "type": "text",
      "required": false,
      "flag": "--email",
      "description": "Email address for alerts.",
      "placeholder": "security@example.com"
    },
    {
      "name": "dashboard",
      "label": "Enable dashboard",
      "type": "boolean",
      "required": false,
      "flag": "--dashboard",
      "description": "Enable the dashboard option from the command examples.",
      "defaultValue": false
    }
  ],
  "remove": [
    "commaSeparatedFrameworksEGSOC2PCIDSSNIST)",
    "scheduleOptionalDailyWeeklyHourlyDefaultDaily)",
    "optionsOptionalSlackWebhookURLEmailAddressDashboard`"
  ],
  "order": [
    "frameworks",
    "schedule",
    "slackWebhook",
    "email",
    "dashboard"
  ],
  "submitLabel": "Run Monitor Continuous"
}
