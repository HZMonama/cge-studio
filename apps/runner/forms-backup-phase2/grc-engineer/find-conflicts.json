{
  "mode": "inline",
  "minimumConfiguration": [
    "frameworks"
  ],
  "fields": [
    {
      "name": "frameworks",
      "label": "Frameworks",
      "type": "text",
      "required": true,
      "position": "argument",
      "description": "Comma-separated framework codes to compare.",
      "placeholder": "SOC2,PCI-DSS,NIST"
    },
    {
      "name": "detailLevel",
      "label": "Detail Level",
      "type": "select",
      "required": false,
      "position": "argument",
      "description": "Choose summary or detailed conflict analysis. Omit to use the CLI default.",
      "options": [
        { "label": "Summary", "value": "summary" },
        { "label": "Detailed", "value": "detailed" }
      ]
    }
  ],
  "remove": [
    "commaSeparatedListOfFrameworksEGSOC2PCIDSSNIST)",
    "detailLevelOptionalSummaryOrDetailedDefaultDetailed)"
  ],
  "order": [
    "frameworks",
    "detailLevel"
  ],
  "submitLabel": "Run Find Conflicts"
}
