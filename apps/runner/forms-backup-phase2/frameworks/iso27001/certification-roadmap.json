        { "label": "Low", "value": "low" },
        { "label": "Medium", "value": "medium" },
        { "label": "High", "value": "high" }
      ]
    },
    {
      "name": "scope",
      "label": "Scope",
      "type": "select",
      "required": false,
      "flag": "--scope",
      "description": "Target certification scope profile.",
      "options": [
        { "label": "Cloud Only", "value": "cloud-only" },
        { "label": "Hybrid", "value": "hybrid" }
      ]
    },
    {
      "name": "fastTrack",
      "label": "Fast-track roadmap",
      "type": "boolean",
      "required": false,
      "flag": "--fast-track",
      "description": "Generate the accelerated certification path.",
      "defaultValue": false
