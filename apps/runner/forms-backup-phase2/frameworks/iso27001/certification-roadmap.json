{
  "mode": "inline",
  "fields": [
    {
      "name": "targetDate",
      "label": "Target Date",
      "type": "text",
      "required": false,
      "position": "argument",
      "description": "Optional target certification date or duration.",
      "defaultValue": "12-months",
      "placeholder": "2025-12-31 or 12-months"
    },
    {
      "name": "currentMaturity",
      "label": "Current Maturity",
      "type": "select",
      "required": false,
      "flag": "--current-maturity",
      "description": "Current ISO program maturity level.",
