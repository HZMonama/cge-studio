        { "label": "General", "value": "general" },
        { "label": "Cloud", "value": "cloud" },
        { "label": "Mobile", "value": "mobile" },
        { "label": "Industrial", "value": "industrial" }
      ]
    }
  ],
  "overrides": {},
  "remove": [],
